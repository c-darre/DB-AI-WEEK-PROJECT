<nav class="sa-navbar">
  <div class="container sa-navbar__inner">
    <%= link_to root_path, class: "sa-navbar__brand" do %>
      <span class="sa-navbar__logo">S</span>
      <span>SneakerAI</span>
    <% end %>

    <div class="sa-navbar__links">
      <% if user_signed_in? %>
        <span class="sa-navbar__email"><%= current_user.email %></span>

        <%= link_to "Historique", chats_path, class: "sa-navbar__link" %>

        <%= link_to "Déconnexion",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "sa-btn sa-btn--ghost" %>
      <% else %>
        <%= link_to "Se connecter",
          new_user_session_path,
          class: "sa-navbar__link" %>

        <%= link_to "S'inscrire",
          new_user_registration_path,
          class: "sa-btn sa-btn--primary" %>
      <% end %>
    </div>
  </div>
</nav>
