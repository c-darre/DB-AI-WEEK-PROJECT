<nav class="navbar navbar-light bg-light mb-4 navbar-lewagon">

  <div class="container d-flex align-items-center gap-3">

    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#mobileMenu">

      <span class="navbar-toggler-icon"></span>

    </button>

    <%= link_to "SneakerAI",
      root_path,
      class: "navbar-brand fw-bold mb-0" %>

  </div>

</nav>

<div class="offcanvas offcanvas-start"
     tabindex="-1"
     id="mobileMenu">

  <div class="offcanvas-header">

    <h5 class="offcanvas-title fw-bold">
      SneakerAI
    </h5>

    <button type="button"
            class="btn-close"
            data-bs-dismiss="offcanvas">
    </button>

  </div>

  <div class="offcanvas-body d-flex flex-column">

    <div class="d-grid gap-2">

      <%= button_to chats_path,
        method: :post,
        class: "btn btn-primary rounded-pill text-start fw-semibold" do %>

        + Nouveau chat

      <% end %>

      <%= link_to "Historique",
        chats_path,
        class: "btn btn-light rounded-pill text-start fw-semibold" %>

    </div>

    <hr>

    <% if user_signed_in? %>

      <% recent_chats = current_user.chats
          .includes(:messages)
          .order(created_at: :desc)
          .limit(3) %>

      <% if recent_chats.any? %>

        <div class="mt-4">

          <p class="text-uppercase text-muted fw-bold small mb-3">
            Recent
          </p>

          <div class="d-flex flex-column gap-2">

            <% recent_chats.each do |chat| %>

              <% first_message = chat.messages
                  .where.not(content: [nil, ""])
                  .order(created_at: :asc)
                  .first %>

              <% generated_title =
                  first_message&.content
                    &.split
                    &.first(4)
                    &.join(" ") || "Nouvelle conversation" %>

              <%= link_to chat_path(chat),
                class: "text-decoration-none rounded-pill px-3 py-2 bg-light text-dark small fw-semibold" do %>

                <%= "#{generated_title.truncate(22, omission: '')}..." %>

              <% end %>

            <% end %>

          </div>

        </div>

      <% end %>

      <div class="mt-auto">

        <p class="text-muted small mb-2">
          <%= current_user.email %>
        </p>

        <%= link_to "Déconnexion",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "btn btn-outline-primary rounded-pill w-100 fw-semibold" %>

      </div>

    <% else %>

      <div class="mt-auto d-grid gap-2">

        <%= link_to "Se connecter",
          new_user_session_path,
          class: "btn btn-light rounded-pill" %>

        <%= link_to "S'inscrire",
          new_user_registration_path,
          class: "btn btn-primary rounded-pill" %>

      </div>

    <% end %>

  </div>

</div>
