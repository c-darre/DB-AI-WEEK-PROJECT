<div class="navbar navbar-expand-sm navbar-light bg-light mb-4">
  <div class="container">
    <%= link_to "SneakerAI", root_path, class: "navbar-brand fw-bold" %>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav ms-auto">
        <% if user_signed_in? %>
          <li class="nav-item">
            <span class="nav-link text-secondary">Profil de <%= current_user.email %></span>
          </li>
          <li class="nav-item">
            <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Se connecter", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "S'inscrire", new_user_registration_path, class: "btn btn-primary ms-2" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
