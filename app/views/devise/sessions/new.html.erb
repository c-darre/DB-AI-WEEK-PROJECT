<div class="sa-auth-page">
  <div class="sa-auth-card">
    <div class="sa-auth-logo">S</div>

    <span class="sa-pill">
      <i class="fa-solid fa-lock"></i>
      Connexion
    </span>

    <h1>Bon retour sur SneakerAI</h1>

    <p>
      Connecte-toi pour retrouver tes analyses et continuer tes conversations.
    </p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="sa-auth-form">
        <%= f.input :email,
          required: false,
          autofocus: true,
          label: "Email",
          input_html: {
            autocomplete: "email",
            class: "sa-auth-input"
          } %>

        <%= f.input :password,
          required: false,
          label: "Mot de passe",
          input_html: {
            autocomplete: "current-password",
            class: "sa-auth-input"
          } %>

        <% if devise_mapping.rememberable? %>
          <%= f.input :remember_me,
            as: :boolean,
            label: "Se souvenir de moi" %>
        <% end %>

        <%= f.button :submit,
          "Se connecter",
          class: "sa-btn sa-btn--primary sa-btn--lg w-100" %>
      </div>
    <% end %>

    <div class="sa-auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
