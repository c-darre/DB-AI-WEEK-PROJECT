<div class="sa-auth-page">
  <div class="sa-auth-card">
    <div class="sa-auth-logo">S</div>

    <span class="sa-pill">
      <i class="fa-solid fa-user-plus"></i>
      Inscription
    </span>

    <h1>Créer ton compte SneakerAI</h1>

    <p>
      Lance tes analyses IA, sauvegarde ton historique et compare tes sneakers.
    </p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>

      <div class="sa-auth-form">
        <%= f.input :email,
          required: true,
          autofocus: true,
          label: "Email",
          input_html: {
            autocomplete: "email",
            class: "sa-auth-input"
          } %>

        <%= f.input :password,
          required: true,
          label: "Mot de passe",
          hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
          input_html: {
            autocomplete: "new-password",
            class: "sa-auth-input"
          } %>

        <%= f.input :password_confirmation,
          required: true,
          label: "Confirmation du mot de passe",
          input_html: {
            autocomplete: "new-password",
            class: "sa-auth-input"
          } %>

        <%= f.button :submit,
          "Créer mon compte",
          class: "sa-btn sa-btn--primary sa-btn--lg w-100" %>
      </div>
    <% end %>

    <div class="sa-auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
