<div class="sa-auth-page">
  <div class="sa-auth-card">
    <div class="sa-auth-logo">S</div>

    <span class="sa-pill">
      <i class="fa-solid fa-user-gear"></i>
      Profil
    </span>

    <h1>Modifier mon compte</h1>

    <p>Mets à jour ton email ou ton mot de passe.</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <div class="sa-auth-form">
        <%= f.input :email, required: true, label: "Email", input_html: { class: "sa-auth-input" } %>

        <%= f.input :password,
          required: false,
          label: "Nouveau mot de passe",
          hint: "Laisse vide si tu ne veux pas le changer",
          input_html: { autocomplete: "new-password", class: "sa-auth-input" } %>

        <%= f.input :password_confirmation,
          required: false,
          label: "Confirmer le nouveau mot de passe",
          input_html: { autocomplete: "new-password", class: "sa-auth-input" } %>

        <%= f.input :current_password,
          required: true,
          label: "Mot de passe actuel",
          hint: "Nécessaire pour confirmer les changements",
          input_html: { autocomplete: "current-password", class: "sa-auth-input" } %>

        <%= f.button :submit, "Mettre à jour", class: "sa-btn sa-btn--primary sa-btn--lg w-100" %>
      </div>
    <% end %>

    <div class="sa-danger-zone">
      <h2>Zone dangereuse</h2>

      <%= button_to "Supprimer mon compte",
        registration_path(resource_name),
        data: { turbo_confirm: "Es-tu sûr ?" },
        method: :delete,
        class: "sa-btn sa-btn--danger w-100" %>
    </div>

    <div class="sa-auth-links">
      <%= link_to "Retour", :back %>
    </div>
  </div>
</div>
