<div class="sa-auth-page">
  <div class="sa-auth-card">
    <div class="sa-auth-logo">S</div>

    <span class="sa-pill">
      <i class="fa-solid fa-lock-open"></i>
      Nouveau mot de passe
    </span>

    <h1>Choisir un nouveau mot de passe</h1>

    <p>Définis un nouveau mot de passe sécurisé.</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>
      <%= f.input :reset_password_token, as: :hidden %>

      <div class="sa-auth-form">
        <%= f.input :password,
          required: true,
          autofocus: true,
          label: "Nouveau mot de passe",
          hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
          input_html: { autocomplete: "new-password", class: "sa-auth-input" } %>

        <%= f.input :password_confirmation,
          required: true,
          label: "Confirmer le mot de passe",
          input_html: { autocomplete: "new-password", class: "sa-auth-input" } %>

        <%= f.button :submit,
          "Changer mon mot de passe",
          class: "sa-btn sa-btn--primary sa-btn--lg w-100" %>
      </div>
    <% end %>

    <div class="sa-auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
