<div class="sa-auth-page">
  <div class="sa-auth-card">
    <div class="sa-auth-logo">S</div>

    <span class="sa-pill">
      <i class="fa-solid fa-key"></i>
      Mot de passe oublié
    </span>

    <h1>Réinitialiser mon mot de passe</h1>

    <p>Entre ton email et nous t’enverrons les instructions.</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <div class="sa-auth-form">
        <%= f.input :email,
          required: true,
          autofocus: true,
          label: "Email",
          input_html: { autocomplete: "email", class: "sa-auth-input" } %>

        <%= f.button :submit,
          "Envoyer les instructions",
          class: "sa-btn sa-btn--primary sa-btn--lg w-100" %>
      </div>
    <% end %>

    <div class="sa-auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
