  <div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="mb-4 text-center"><%= @chat.title || "Nouvelle discussion" %></h1>

      <div id="new_message_container" class="text-start">
        <div id="messages">
          <% @chat.messages.each do |message| %>
            <% if message.role == "user" %>
              <div class="d-flex justify-content-end mb-2">
                <div class="bg-white p-3 rounded-pill">
                  <%# --- NOUVEAU : Affichage de la photo si elle existe --- %>
                    <% if message.photo.attached? %>
                      <%= image_tag message.photo, class: "img-fluid rounded mb-2", style: "max-width: 200px; display: block;" %>
                    <% end %>
                  <%# ---------------------------------------------------- %>
                  <%= message.content %>
                </div>
              </div>
            <% elsif message.role == "assistant" %>
              <div class="d-flex justify-content-start mb-5">
                <div class="bg-white p-3 rounded-4">
                  <%= raw(render_markdown(message.content)) %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        </div>
        <%= simple_form_for [@chat, @message] do |f| %>
          <%= f.input :content, label: false, placeholder: "Ex: Peux-tu analyser les coutures de cette Jordan 4 ?", as: :string %>
          <%= f.input :photo, as: :file, class:'' %>
          <div class="d-flex justify-content-end mt-2">
            <%= f.button :submit, 'Lancer l\'analyse', class: 'btn btn_sneaky' %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>
