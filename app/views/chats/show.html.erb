<div class="container mt-5">
  <%= turbo_stream_from @chat %>
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="mb-4 text-center" id="chat_title"><%= @chat.title || "Nouvelle discussion" %></h1>

      <div class="text-start">
        <%# 1. La zone des messages (bien séparée du formulaire) avec tri obligatoire %>
        <div id="messages">
          <%= render @chat.messages.order(created_at: :asc) %>
        </div>

        <%# 2. La zone du formulaire %>
        <div id="new_message_container" class="mt-4">
          <%= render "messages/form", chat: @chat, message: Message.new %>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.getElementById('camera_input').addEventListener('change', function() {
    const mainInput = document.getElementById('main_photo_input');
    try {
      const dt = new DataTransfer();
      dt.items.add(this.files[0]);
      mainInput.files = dt.files;
    } catch(e) {
      // Fallback : cache l'input fichier et utilise directement camera_input
      mainInput.style.display = 'none';
      mainInput.removeAttribute('name');
      this.setAttribute('name', 'message[photo]');
    }
  });
</script>
