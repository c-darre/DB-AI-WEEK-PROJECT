<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="mb-4 text-center"><%= @chat.title || "Nouvelle discussion" %></h1>

      <div id="new_message_container" class="text-start">
        <div id="messages">
          <% @chat.messages.each do |message| %>
            <% if message.role == "user" %>
              <div class="d-flex justify-content-end mb-2">
                <div class="bg-white p-3 rounded-pill">
                  <% if message.photo.attached? %>
                    <%= image_tag message.photo, class: "img-fluid rounded mb-2", style: "max-width: 200px; display: block;" %>
                  <% end %>
                  <%= message.content %>
                </div>
              </div>
            <% elsif message.role == "assistant" %>
              <div class="d-flex justify-content-start mb-5">
                <div class="bg-white p-3 rounded-4">
                  <%= raw(render_markdown(message.content)) %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <%= simple_form_for [@chat, @message] do |f| %>
          <%= f.input :content, label: false,
              placeholder: "Ex: Peux-tu analyser les coutures de cette Jordan 4 ?",
              as: :string,
              input_html: { class: 'form_control' } %>

          <div class="d-flex align-items-center gap-2">
            <%= f.input :photo, as: :file, label: false,
                wrapper_html: { style: 'flex: 1; margin-bottom: 0;' },
                input_html: { id: 'main_photo_input', class: 'form_control', accept: "image/*" } %>

            <label for="camera_input" class="btn_camera">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="6" width="20" height="15" rx="3"/>
                <circle cx="12" cy="13" r="4"/>
                <path d="M8 6l1.5-3h5L16 6"/>
              </svg>
              Photo
            </label>
            <input type="file" id="camera_input" accept="image/*" capture="environment" style="display: none;">
          </div>

          <div class="d-flex justify-content-end mt-2">
            <%= f.button :submit, 'Lancer l\'analyse', class: 'btn btn_sneaky rounded-pill px-4' %>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('camera_input').addEventListener('change', function() {
    const mainInput = document.getElementById('main_photo_input');
    const dt = new DataTransfer();
    dt.items.add(this.files[0]);
    mainInput.files = dt.files;
  });
</script>
