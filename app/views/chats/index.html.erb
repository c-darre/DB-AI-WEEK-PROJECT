<div class="sa-history-page">
  <div class="container">
    <div class="sa-history-header">
      <div>
        <span class="sa-pill">
          <i class="fa-solid fa-clock-rotate-left"></i>
          Historique
        </span>

        <h1>Tes conversations SneakerAI</h1>

        <p>
          Retrouve tes anciennes analyses et reprends une conversation quand tu veux.
        </p>
      </div>

      <%= button_to chats_path,
        method: :post,
        class: "sa-btn sa-btn--primary sa-btn--lg" do %>
        <i class="fa-solid fa-plus"></i>
        Nouvelle analyse
      <% end %>
    </div>

    <% if @chats.any? %>
      <div class="sa-history-grid">
        <% @chats.each do |chat| %>
          <div class="sa-history-card">
            <div class="sa-history-card__icon">
              <i class="fa-solid fa-comments"></i>
            </div>

            <div class="sa-history-card__content">
              <h2><%= chat.title.presence || "Nouvelle conversation" %></h2>

              <p>
                Créée le
                <%= l(chat.created_at, format: :short) rescue chat.created_at.strftime("%d/%m/%Y %H:%M") %>
              </p>
            </div>

            <%= link_to chat_path(chat), class: "sa-history-card__link" do %>
              Ouvrir
              <i class="fa-solid fa-arrow-right"></i>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="sa-empty-state">
        <div class="sa-empty-state__icon">
          <i class="fa-solid fa-shoe-prints"></i>
        </div>

        <h2>Aucune conversation pour le moment</h2>

        <p>
          Lance ta première analyse IA pour commencer à construire ton historique.
        </p>

        <%= button_to chats_path,
          method: :post,
          class: "sa-btn sa-btn--primary sa-btn--lg" do %>
          Démarrer une analyse
        <% end %>
      </div>
    <% end %>
  </div>
</div>
