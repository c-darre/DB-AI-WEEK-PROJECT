<h1>Recommendations#index</h1>
<p>Find me in app/views/recommendations/index.html.erb</p>

<div class="row">
  <% @recommendations.each do |message| %>
    <div class="col-md-4 mb-4">
      <div class="card">
        <img src="<%= message.image_url %>" class="card-img-top" alt="<%= message.content %>" style="height: 800px; object-fit: cover;">
        <div class="card-body">
          <p class="card-text"><%= message.content %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
