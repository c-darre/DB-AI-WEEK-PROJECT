<div class="container py-4">
  <h1 class="text-center fw-bold mb-4">Mes Recommandations 👟</h1>

  <div class="row g-3">
    <% @recommendations.each do |message| %>
      <div class="col-12 col-sm-6 col-md-4">
        <div class="card h-100 border-0 shadow-sm">
          <img src="<%= message.image_url %>" class="card-img-top" alt="<%= message.content %>" style="height: 300px; object-fit: cover;">
          <div class="card-body">
            <p class="card-text text-muted small"><%= message.content %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
