<%= simple_form_for [chat, message] do |f| %>
          <%= f.input :content, label: false,
              placeholder: "Ex: Peux-tu analyser les coutures de cette Jordan 4 ?",
              as: :string,
              input_html: { class: 'form_control' } %>

          <div class="d-flex align-items-center gap-2">
            <%= f.input :photo, as: :file, label: false,
                wrapper_html: { style: 'flex: 1; margin-bottom: 0;' },
                input_html: { id: 'main_photo_input', class: 'form_control', accept: "image/*" } %>

            <label for="camera_input" class="btn_camera">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="6" width="20" height="15" rx="3"/>
                <circle cx="12" cy="13" r="4"/>
                <path d="M8 6l1.5-3h5L16 6"/>
              </svg>
              Photo
            </label>
            <input type="file" id="camera_input" accept="image/*" capture="environment" style="display: none;">
          </div>

          <div class="d-flex justify-content-end mt-2">
            <%= f.button :submit, 'Lancer l\'analyse', class: 'btn btn_sneaky rounded-pill px-4' %>
          </div>
        <% end %>
